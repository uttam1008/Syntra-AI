# Copy this to .env and fill in your values
# NEVER commit the real .env file to git

# Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
# Local: postgresql+asyncpg://postgres:password@localhost:5432/syntra_db
# Railway: auto-provided as DATABASE_URL environment variable
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/syntra_db

# Optional — only needed if routing to these providers
OPENROUTER_API_KEY=
GROQ_API_KEY=
